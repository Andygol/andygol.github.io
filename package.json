{
  "title": "Andrii Holovin personal website",
  "name": "andrii-holovin-personal-website",
  "version": "2.1.1",
  "scripts": {
    "build": "hugo --minify",
    "serve": "hugo server --disableFastRender --buildDrafts --gc",
    "serve:debug": "hugo server --disableFastRender --buildDrafts --logLevel debug"
  },
  "description": "A personal website built with Hugo, Tailwind CSS, and React islands",
  "keywords": [
    "css",
    "sass",
    "html",
    "responsive",
    "theme",
    "template"
  ],
  "homepage": "https://andygol.co.ua/",
  "bugs": {
    "url": "https://github.com/Andygol/andygol.github.io/issues"
  },
  "license": "MIT",
  "author": "Andrii Holovin (https://andygol.co.ua/)",
  "repository": {
    "type": "git",
    "url": "https://github.com/Andygol/andygol.github.io.git"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "hugo-extended": "^0.163.3",
    "prettier": "3.9.4",
    "tailwindcss": "^4.3.0"
  }
}
